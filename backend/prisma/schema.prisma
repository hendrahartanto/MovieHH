// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  name         String
  role         Role          @default(USER)
  password     String
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Movie {
  id             String           @id @default(uuid()) @db.Uuid
  title          String
  synopsis       String?
  posterUrl      String?
  bannerUrl      String?
  duration       Int
  director       String?
  writer         String?
  isFeatured     Boolean
  status         MovieStatus
  trailerUrl     String?
  genres         GenresOnMovies[]
  movieSchedules MovieSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genre {
  id     String           @id @default(uuid()) @db.Uuid
  name   String           @unique
  movies GenresOnMovies[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenresOnMovies {
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId String @db.Uuid
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)
  genreId String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([movieId, genreId])
}

model Location {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  address  String
  theaters Theater[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Theater {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  layout     Json
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String   @db.Uuid

  seats          Seat[]
  movieSchedules MovieSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seat {
  id                 String              @id @default(uuid()) @db.Uuid
  seatNumber         String
  seatRow            String
  theater            Theater             @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  theaterId          String              @db.Uuid
  showTimes          SeatsOnShowTimes[]
  reservationDetails ReservationDetail[]
}

model MovieSchedule {
  id        String     @id @default(uuid()) @db.Uuid
  movie     Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   String     @db.Uuid
  theater   Theater    @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  theaterId String     @db.Uuid
  price     Decimal
  date      DateTime
  showTimes ShowTime[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShowTime {
  id              String             @id @default(uuid()) @db.Uuid
  movieSchedule   MovieSchedule      @relation(fields: [movieScheduleId], references: [id], onDelete: Cascade)
  movieScheduleId String             @db.Uuid
  startTime       DateTime
  endTime         DateTime
  reservations    Reservation[]
  seats           SeatsOnShowTimes[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model SeatsOnShowTimes {
  seat       Seat       @relation(fields: [seatId], references: [id], onDelete: Cascade)
  seatId     String     @db.Uuid
  showTime   ShowTime   @relation(fields: [showTimeId], references: [id], onDelete: Cascade)
  showTimeId String     @db.Uuid
  status     SeatStatus @default(AVAILABLE)

  @@id([seatId, showTimeId])
}

model Reservation {
  id                 String              @id @default(uuid()) @db.Uuid
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String              @db.Uuid
  showTime           ShowTime            @relation(fields: [showTimeId], references: [id], onDelete: Cascade)
  showTimeId         String              @db.Uuid
  status             ReservationStatus   @default(PENDING)
  totalPrice         Decimal
  expiresAt          DateTime
  createAt           DateTime            @default(now())
  reservationDetails ReservationDetail[]
}

model ReservationDetail {
  id            String      @id @default(uuid()) @db.Uuid
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String      @db.Uuid
  seat          Seat        @relation(fields: [seatId], references: [id], onDelete: Cascade)
  seatId        String      @db.Uuid
}

enum MovieStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum SeatStatus {
  AVAILABLE
  HOLD
  RESERVED
}
