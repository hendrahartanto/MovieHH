// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(uuid()) @db.Uuid
  email       String        @unique
  name        String
  role        Role          @default(USER)
  password    String
  reservation Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Movie {
  id          String           @id @default(uuid()) @db.Uuid
  title       String
  description String
  posterUrl   String?
  genres      GenresOnMovies[]
  showTime    ShowTime[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genre {
  id     String           @id @default(uuid()) @db.Uuid
  name   String           @unique
  movies GenresOnMovies[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenresOnMovies {
  movie   Movie  @relation(fields: [moveiId], references: [id])
  moveiId String @db.Uuid
  genre   Genre  @relation(fields: [genreId], references: [id])
  genreId String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([moveiId, genreId])
}

model Theater {
  id       String     @id @default(uuid()) @db.Uuid
  name     String
  seat     Seat[]
  showTime ShowTime[]
}

model Seat {
  id          String        @id @default(uuid()) @db.Uuid
  seatNumber  String
  seatRow     String
  theater     Theater       @relation(fields: [theaterId], references: [id])
  theaterId   String        @db.Uuid
  reservation Reservation[]
}

model ShowTime {
  id         String        @id @default(uuid()) @db.Uuid
  movie      Movie         @relation(fields: [movieId], references: [id])
  movieId    String        @db.Uuid
  theater    Theater       @relation(fields: [theaterId], references: [id])
  theaterId  String        @db.Uuid
  startTime  DateTime
  endTime    DateTime
  reservatio Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id         String            @id @default(uuid()) @db.Uuid
  user       User              @relation(fields: [userId], references: [id])
  userId     String            @db.Uuid
  showTime   ShowTime          @relation(fields: [showTimeId], references: [id])
  showTimeId String            @db.Uuid
  seat       Seat              @relation(fields: [seatId], references: [id])
  seatId     String            @db.Uuid
  status     ReservationStatus @default(PENDING)
  createAt   DateTime          @default(now())
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
}
