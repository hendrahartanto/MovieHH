FROM node:20-alpine

WORKDIR /app

# Install dependencies first for caching
COPY package*.json ./
RUN npm install

# Copy prisma schema first to generate Prisma Client
COPY prisma ./prisma
RUN npx prisma generate

# Copy the rest of the application files
COPY . .

# Expose backend port
EXPOSE 3000

# Start server
CMD ["npm", "run", "dev"]
